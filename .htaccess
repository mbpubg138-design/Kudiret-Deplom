Options -Indexes

<Files "database.sql">
  Require all denied
</Files>

<FilesMatch "^(README.*\.txt|.*\.md)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.(log|env|bak|old)$">
  Require all denied
</FilesMatch>

<FilesMatch "^(config\.php|db\.php|csrf\.php)$">
  Require all denied
</FilesMatch>
